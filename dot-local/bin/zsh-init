#!/bin/bash
# Regenerate zsh cache files for faster shell startup
# Usage: zsh-init [--brew] [--vivid] [--fnm] [--zoxide] [--starship] [--all] [--help]
# If no arguments provided, defaults to --all

set -euo pipefail

XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"

# Show help message
show_help() {
    cat <<EOF
Usage: zsh-init [OPTIONS]

Regenerate zsh cache files for faster shell startup.

Options:
  --brew      Regenerate homebrew shellenv cache
  --vivid     Regenerate vivid LS_COLORS cache
  --fnm       Regenerate fnm environment cache
  --zoxide    Regenerate zoxide init cache
  --starship  Regenerate starship init cache
  --all       Regenerate all caches (default if no options)
  --help      Show this help message

Examples:
  zsh-init              # Regenerate all caches
  zsh-init --brew       # Only regenerate homebrew cache
  zsh-init --fnm --zoxide  # Regenerate fnm and zoxide caches
EOF
}

# Helper function to generate cache
generate_cache() {
    local name="$1"
    local cache_path="$2"
    local command="$3"

    mkdir -p "$(dirname "$cache_path")"
    if eval "$command" > "$cache_path" 2>/dev/null; then
        echo "✓ $name"
    else
        echo "✗ $name (not installed or failed)"
        rm -f "$cache_path"
    fi
}

# Parse arguments
do_all=false
do_brew=false
do_vivid=false
do_fnm=false
do_zoxide=false
do_starship=false

# If no args, default to all
if [[ $# -eq 0 ]]; then
    do_all=true
fi

# Parse flags
for arg in "$@"; do
    case "$arg" in
        --all) do_all=true ;;
        --brew) do_brew=true ;;
        --vivid) do_vivid=true ;;
        --fnm) do_fnm=true ;;
        --zoxide) do_zoxide=true ;;
        --starship) do_starship=true ;;
        --help) show_help; exit 0 ;;
        *) echo "Unknown option: $arg"; show_help; exit 1 ;;
    esac
done

echo "Regenerating zsh cache files..."

# Homebrew shellenv
if [[ "$do_all" == true || "$do_brew" == true ]]; then
    brew_cache="$XDG_CACHE_HOME/homebrew/shellenv.zsh"
    if [[ -f /opt/homebrew/bin/brew ]]; then
        generate_cache "homebrew" "$brew_cache" "/opt/homebrew/bin/brew shellenv"
    elif [[ -f /usr/local/bin/brew ]]; then
        generate_cache "homebrew" "$brew_cache" "/usr/local/bin/brew shellenv"
    else
        echo "✗ homebrew (not installed)"
    fi
fi

# Vivid LS_COLORS
if [[ "$do_all" == true || "$do_vivid" == true ]]; then
    generate_cache "vivid" "$XDG_CACHE_HOME/vivid/ls_colors" "vivid generate tokyonight-night"
fi

# fnm environment
if [[ "$do_all" == true || "$do_fnm" == true ]]; then
    generate_cache "fnm" "$XDG_CACHE_HOME/zsh/fnm.zsh" "fnm env --use-on-cd --corepack-enabled --resolve-engines --version-file-strategy=recursive --shell zsh"
fi

# zoxide init
if [[ "$do_all" == true || "$do_zoxide" == true ]]; then
    generate_cache "zoxide" "$XDG_CACHE_HOME/zsh/zoxide.zsh" "zoxide init zsh"
fi

# starship init
if [[ "$do_all" == true || "$do_starship" == true ]]; then
    generate_cache "starship" "$XDG_CACHE_HOME/zsh/starship.zsh" "starship init zsh"
fi

echo "Done."
